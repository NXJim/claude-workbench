[Unit]
Description=Claude Workbench — Terminal Manager
After=network.target

[Service]
Type=simple
User=%USER%
WorkingDirectory=%WORKDIR%/backend
Environment=PATH=%VENV%/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=-%WORKDIR%/.env
ExecStart=%VENV%/bin/python -m uvicorn main:app --host 0.0.0.0 --port %PORT%
Restart=on-failure
RestartSec=5
# Only kill the main uvicorn process on stop/restart — leave tmux sessions alive
KillMode=process

[Install]
WantedBy=multi-user.target
