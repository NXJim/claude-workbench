# Claude Workbench Configuration
# Copy to .env and customize as needed. All values have sensible defaults.

# Public hostname/IP for browser access (auto-detected if unset)
# CWB_PUBLIC_HOST=192.168.1.100

# Backend API port (serves everything in production)
# CWB_BACKEND_PORT=5173

# Frontend port (used in dev mode with Vite)
# CWB_FRONTEND_PORT=5174

# Root directory for project discovery
# CWB_PROJECTS_ROOT=~/projects

# ttyd port range (one port per terminal session)
# CWB_TTYD_PORT_BASE=9100
# CWB_TTYD_PORT_MAX=9200
